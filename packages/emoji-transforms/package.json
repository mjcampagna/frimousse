{
  "name": "@slithy/emoji-transforms",
  "description": "Emoji metadata transforms for search enrichment and related tooling.",
  "version": "0.1.1",
  "type": "module",
  "sideEffects": false,
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "rm -rf dist && tsup",
    "dev": "tsup --watch",
    "lint:package": "publint --strict",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "publint": "^0.3.9",
    "tsup": "^8.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "emoji",
    "shortcodes",
    "search",
    "metadata"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mjcampagna/frimousse.git",
    "directory": "packages/emoji-transforms"
  },
  "bugs": {
    "url": "https://github.com/mjcampagna/frimousse/issues"
  },
  "homepage": "https://frimousse.slithy.me/docs/api-reference#emoji-transforms-api"
}
