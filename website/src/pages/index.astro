---
import { PickerDemo } from "../components/demo/PickerDemo";
import SiteHeader from "../components/SiteHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Frimousse by Slithy"
  description="A compatibility-conscious fork of frimousse with additive extensions and a static-first docs site."
>
  <main class="page-shell">
    <SiteHeader />

    <section class="hero">
      <div class="hero-copy">
        <h1>A composable emoji picker for React, built on tiny faces.</h1>
        <p class="subhead">
          A compatibility-conscious fork of
          {" "}
          <a
            href="https://github.com/liveblocks/frimousse"
            rel="nofollow noreferrer noopener"
            target="_blank"
          >
            Frimousse
          </a>.
        </p>
        <p class="lede">
          `@slithy/frimousse` keeps the baseline picker contract familiar while
          adding general-purpose extension seams for mixed sections, custom
          emoji, unified search, and consumer-owned frequent items.
        </p>
      </div>

      <div class="hero-callout">
        <p class="callout-label">Install</p>
        <pre><code>pnpm add @slithy/frimousse</code></pre>
        <p class="callout-copy">
          Existing consumers should be able to swap the import source and keep
          moving.
        </p>
      </div>
    </section>

    <div id="demo">
      <PickerDemo client:load />
    </div>
  </main>
</BaseLayout>
