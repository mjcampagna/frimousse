---
import BaseApiSection from "../content/docs/base-api.mdx";
import ExtendedApiSection from "../content/docs/extended-api.mdx";
import SetupSection from "../content/docs/installation.mdx";
import BaseApiDemoIsland from "../components/docs/BaseApiDemoIsland.astro";
import ExtendedApiDemoIsland from "../components/docs/ExtendedApiDemoIsland.astro";
import NativeSearchDemoIsland from "../components/docs/NativeSearchDemoIsland.astro";
import NativeShortcodeDemoIsland from "../components/docs/NativeShortcodeDemoIsland.astro";
import ShortcodeFirstDemoIsland from "../components/docs/ShortcodeFirstDemoIsland.astro";
import SupplementalPackagesSection from "../content/docs/supplemental-packages.mdx";
import SiteHeader from "../components/SiteHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Documentation — Frimousse by Slithy"
  description="Documentation and demos for Frimousse by Slithy, including its additive extension seams and companion packages."
>
  <main class="docs-page-shell">
    <SiteHeader />

    <section class="docs-hero">
      <div class="docs-hero-copy">
        <p class="eyebrow">Documentation</p>
        <h1>One picker, layered contracts.</h1>
        <p class="lede">
          Frimousse by Slithy keeps the base composition model intact, adds
          useful extension seams, and leaves broader emoji metadata policy to
          companion packages.
        </p>
      </div>

      <div class="docs-summary">
        <a class="docs-summary-card" href="#installation">
          <h2>Installation</h2>
          <p>Install the package, then update imports in existing Frimousse usage.</p>
        </a>
        <a class="docs-summary-card" href="#base-api">
          <h2>Base API</h2>
          <p>Core picker parts, grouped search, and native-only helpers.</p>
        </a>
        <a class="docs-summary-card" href="#extended-api">
          <h2>Extended API</h2>
          <p>Supplemental items, unified search, and consumer-owned frequent rows.</p>
        </a>
        <a class="docs-summary-card" href="#companion-packages">
          <h2>Companion packages</h2>
          <p>Companion packages that extend search and metadata without changing the picker contract.</p>
        </a>
        <a class="docs-summary-card" href="/docs/api-reference">
          <h2>API Reference</h2>
          <p>Components, props, hooks, helpers, and exported types.</p>
        </a>
      </div>
    </section>

    <div id="installation" class="docs-section-anchor">
      <SetupSection />
    </div>
    <div id="base-api" class="docs-section-anchor">
      <BaseApiSection components={{ BaseApiDemoIsland }} />
    </div>
    <hr class="docs-section-divider" />
    <div id="extended-api" class="docs-section-anchor">
      <ExtendedApiSection components={{ ExtendedApiDemoIsland }} />
    </div>
    <hr class="docs-section-divider" />
    <div id="companion-packages" class="docs-section-anchor">
      <SupplementalPackagesSection
        components={{
          NativeSearchDemoIsland,
          NativeShortcodeDemoIsland,
          ShortcodeFirstDemoIsland,
        }}
      />
    </div>
  </main>
</BaseLayout>
