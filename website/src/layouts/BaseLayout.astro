---
import "../styles/global.css";
import GitHubCorner from "../components/GitHubCorner.astro";

type Props = {
  title: string;
  description?: string;
};

const {
  title,
  description = "A compatibility-conscious fork of frimousse with additive extensions for custom sections, search, and emoji composition.",
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline>
      const storageKey = "slithy-frimousse-theme";
      const root = document.documentElement;
      const media = window.matchMedia("(prefers-color-scheme: dark)");

      const getStoredTheme = () => {
        try {
          return localStorage.getItem(storageKey);
        } catch {
          return null;
        }
      };

      const setStoredTheme = (value) => {
        try {
          localStorage.setItem(storageKey, value);
        } catch {
          // Storage access is optional; keep theme switching working in-memory.
        }
      };

      const preferred = getStoredTheme() ?? (media.matches ? "dark" : "light");

      const applyTheme = (value) => {
        root.dataset.theme = value === "dark" ? "dark" : "light";
        root.dataset.themePreference = value;
      };

      const emitThemeChange = () => {
        window.dispatchEvent(
          new CustomEvent("frimousse-theme-change", {
            detail: { preference: root.dataset.themePreference ?? "light" },
          }),
        );
      };

      applyTheme(preferred);
      emitThemeChange();

      globalThis.__setFrimousseTheme = (value) => {
        setStoredTheme(value);
        applyTheme(value);
        emitThemeChange();
      };

      const syncThemeButtons = () => {
        const current = root.dataset.themePreference ?? "light";
        for (const toggle of document.querySelectorAll(".theme-toggle")) {
          for (const button of toggle.querySelectorAll("[data-theme-target]")) {
            button.toggleAttribute(
              "data-active",
              button.getAttribute("data-theme-target") === current,
            );
          }
        }
      };

      document.addEventListener("click", (event) => {
        const button = event.target instanceof Element
          ? event.target.closest("[data-theme-target]")
          : null;

        if (!(button instanceof HTMLElement)) {
          return;
        }

        globalThis.__setFrimousseTheme?.(
          button.getAttribute("data-theme-target") ?? "light",
        );
      });

      window.addEventListener("frimousse-theme-change", syncThemeButtons);
      syncThemeButtons();
    </script>
  </head>
  <body>
    <GitHubCorner />
    <slot />
  </body>
</html>
