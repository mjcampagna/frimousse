{
  "$schema": "https://turborepo.org/schema.json",
  "extends": ["//"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "outputs": ["dist/**"]
    },
    "test": {
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts"],
      "outputs": ["coverage/**"]
    },
    "lint:tsc": {
      "outputs": []
    },
    "lint:biome": {
      "outputs": []
    },
    "lint:package": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "format": {
      "cache": false,
      "outputs": []
    }
  }
}
