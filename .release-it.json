{
  "$schema": "https://unpkg.com/release-it@18/schema/release-it.json",
  "plugins": {
    "@release-it/keep-a-changelog": {
      "filename": "CHANGELOG.md",
      "addUnreleased": true
    }
  },
  "git": {
    "requireBranch": "main",
    "commitMessage": "Release v${version}",
    "tagName": "v${version}"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "npm": {
    "skipChecks": true
  },
  "hooks": {
    "before:init": ["pnpm build", "pnpm lint"],
    "after:bump": "pnpm format -- package.json"
  }
}
